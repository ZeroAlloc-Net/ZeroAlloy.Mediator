<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>ZeroAlloc.Mediator.Tests</RootNamespace>
    <IsPackable>false</IsPackable>
    <!-- NU1608/NU1701: transitive CodeAnalysis testing packages lack net10 TFM but work fine. -->
    <!-- MA0074: Assert.Contains is an xUnit method, not a string Contains — no StringComparison needed. -->
    <!-- MA0006: string == comparisons in LINQ predicates in test helpers are fine. -->
    <!-- MA0048/MA0051: test files intentionally group related types; long test methods are acceptable. -->
    <!-- MA0008: test-only record structs don't need StructLayout. -->
    <!-- EPS05: fires on auto-generated Mediator.g.cs, not directly fixable here. -->
    <!-- EPS06: ImmutableArray.Where/FirstOrDefault in test helpers; no perf concern in tests. -->
    <!-- HLQ005: Assert.Single is an xUnit method, not LINQ Single. -->
    <NoWarn>$(NoWarn);NU1608;NU1701;MA0074;MA0006;MA0048;MA0051;MA0008;EPS05;EPS06;HLQ005</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.*" />
    <PackageReference Include="xunit" Version="2.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.*" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.12.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Analyzer.Testing" Version="1.*" />
    <PackageReference Include="Microsoft.CodeAnalysis.Testing.Verifiers.XUnit" Version="1.*" />
  </ItemGroup>
  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\ZeroAlloc.Mediator\ZeroAlloc.Mediator.csproj" />
    <ProjectReference Include="..\..\src\ZeroAlloc.Mediator.Generator\ZeroAlloc.Mediator.Generator.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="true" />
    <PackageReference Include="ZeroAlloc.Pipeline.Generators" Version="$(ZeroAllocPipelineVersion)" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <PackageReference Include="ZeroAlloc.Pipeline" Version="$(ZeroAllocPipelineVersion)" />
  </ItemGroup>
</Project>
